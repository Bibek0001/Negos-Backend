{
  // ---------------------------------------------------------------------------
  // DATABASE — uncomment the provider you want to use.
  // The app auto-detects the provider from the connection string format.
  //
  //  SQL Server Express (default — local dev on Windows):
  //    "Server=localhost\\SQLEXPRESS;Database=DiyaloDB;Trusted_Connection=True;TrustServerCertificate=True;"
  //
  //  SQL Server (full / Azure SQL):
  //    "Server=myserver.database.windows.net;Database=DiyaloDB;User Id=sa;Password=yourpassword;TrustServerCertificate=True;"
  //
  //  PostgreSQL (Railway, Supabase, Neon, etc.):
  //    "Host=localhost;Port=5432;Database=DiyaloDB;Username=postgres;Password=yourpassword"
  //
  //  SQLite (zero-config, file-based — great for local dev / testing):
  //    "Data Source=diyalo.db"
  // ---------------------------------------------------------------------------
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=DiyaloDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_YOUR_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "Diyalo.Api",
    "Audience": "Diyalo.Frontend"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "Username": "REPLACE_WITH_YOUR_EMAIL",
    "Password": "REPLACE_WITH_YOUR_APP_PASSWORD",
    "From": "REPLACE_WITH_YOUR_EMAIL"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
