<?xml version="1.0" encoding="utf-8"?>
<!--
  This web.config is used when hosting on IIS with the ASP.NET Core Module.

  stdoutLogEnabled: set to true temporarily to diagnose startup crashes (500.30).
  stdoutLogFile:    path where stdout logs are written — the folder must exist.
  After diagnosing, set stdoutLogEnabled back to false to avoid large log files.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\Diyalo.Api.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!--
            Set your real secrets here OR (preferred) in IIS environment variables
            so they are not stored in this file.

            Example — uncomment and fill in:
            <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
            <environmentVariable name="ConnectionStrings__DefaultConnection" value="Server=...;Database=DiyaloDB;..." />
            <environmentVariable name="Jwt__Key" value="your-very-long-random-secret-key-here" />
            <environmentVariable name="Email__Username" value="your@gmail.com" />
            <environmentVariable name="Email__Password" value="your-app-password" />
            <environmentVariable name="Email__From" value="your@gmail.com" />
            <environmentVariable name="AllowedOrigins" value="https://negos.org" />
          -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
